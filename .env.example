# ── Copiez ce fichier en .env et remplissez les valeurs ──

# MongoDB Atlas connection string
# Créez un compte gratuit sur https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/chrisbasket?retryWrites=true&w=majority

# Secret pour les sessions (changez cette valeur !)
